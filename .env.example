PORT=3000
BASE_URL=https://your-server.example.com
OMI_APP_ID=
OMI_APP_SECRET=
LOG_LEVEL=info

# Demo contact — seeded into every new user's saved contacts so they can
# test the app by saying e.g. "Send a WhatsApp message to Priyanshu Dangi".
# Seeded once per uid; if the user deletes it, it won't be re-added.
# Leave both blank to disable.
DEMO_CONTACT_NAME=Priyanshu Dangi
DEMO_CONTACT_PHONE=+918319645290

# Test runner config (used by test-api.mjs)
HOST=
TEST_UID=
TEST_CONTACT=